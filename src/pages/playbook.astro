---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BlurText from '../components/ui/BlurText';
import GradientText from '../components/ui/GradientText';
import AnimatedButton from '../components/ui/AnimatedButton';
import Magnet from '../components/ui/Magnet';
import RevealText from '../components/ui/RevealText';
import ClickSpark from '../components/ui/ClickSpark';
import SpotlightCard from '../components/ui/SpotlightCard';
import StatsCount from '../components/ui/StatsCount';

const CHECKOUT_URL = "https://buy.stripe.com/eVqfZi5uk8lb4C2fWk1kA00";

const chapters = [
  { num: "01", title: "Why Agentic AI is the Biggest Opportunity", desc: "Market timing, revenue models, and why indie hackers win this wave over enterprises.", icon: "rocket" },
  { num: "02", title: "Agent Architecture 101", desc: "The perception-reasoning-action loop, ReAct pattern, and choosing the right LLM.", icon: "cpu" },
  { num: "03", title: "The Memory Stack", desc: "3-layer memory architecture, vector databases, RAG patterns, and semantic search.", icon: "database" },
  { num: "04", title: "Tool Use & Function Calling", desc: "Giving agents hands — APIs, MCP, custom tools, sandboxing, and security.", icon: "wrench" },
  { num: "05", title: "Prompt Engineering for Agents", desc: "IDENTITY.md pattern, trust ladders, guardrails, and prompt versioning.", icon: "shield" },
  { num: "06", title: "Multi-Agent Systems", desc: "Supervisor, pipeline, and peer-to-peer orchestration with working code.", icon: "network" },
  { num: "07", title: "Shipping to Production", desc: "Observability, error handling, cost management, testing, and deployment.", icon: "ship" },
  { num: "08", title: "5 Agents You Can Build This Weekend", desc: "Complete blueprints for content, support, code review, data, and sales agents.", icon: "blueprint" },
  { num: "09", title: "The Business Side", desc: "Pricing models, cost structure, distribution, legal, and a 90-day launch plan.", icon: "dollar" },
  { num: "10", title: "Templates & Quick-Start Kit", desc: "Copy-paste templates: identity docs, system prompts, eval checklists, and starter scripts.", icon: "template" },
];

const audiences = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    title: "Indie Hackers",
    desc: "You want a proven playbook to build and ship your first AI product, not months of trial and error."
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: "Solo Developers",
    desc: "You can call an API. You need the production engineering playbook to go from playground to paying customers."
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: "Small Teams",
    desc: "Architecture patterns, multi-agent orchestration, and production checklists your whole team can reference."
  },
];

const stats = [
  { value: 31, suffix: "K+", label: "Words of depth" },
  { value: 85, suffix: "+", label: "Pages" },
  { value: 10, suffix: "", label: "Chapters" },
  { value: 5, suffix: "", label: "Build-ready blueprints" },
];

const highlights = [
  "Production-tested architecture patterns",
  "Working Python code in every chapter",
  "Memory, tools, multi-agent & guardrails",
  "5 complete agent blueprints with monetization",
  "Copy-paste templates & starter scripts",
  "Cost optimization & deployment strategies",
];
---

<Layout
  title="Ship Your AI Agent — A Production Playbook | SyncLabs"
  description="31,000-word guide covering agent architecture, memory systems, tool use, multi-agent orchestration, and 5 ready-to-build blueprints. From prototype to paying customers."
>
  <Navbar />
  <main>

    <!-- ===== HERO ===== -->
    <section class="relative min-h-screen flex flex-col justify-center pt-24 pb-20 noise-overlay overflow-hidden">
      <!-- Background glows -->
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-cream/4 rounded-full blur-[200px]"></div>
      <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-cream/3 rounded-full blur-[150px]"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Left: Copy -->
          <div class="text-center lg:text-left">
            <!-- Badge -->
            <div class="animate-fade-in-up mb-6">
              <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cream/8 border border-cream/15 text-xs font-semibold tracking-wide uppercase text-cream/80">
                <span class="w-1.5 h-1.5 rounded-full bg-cream animate-pulse"></span>
                New Release &mdash; 2026 Edition
              </span>
            </div>

            <!-- Headline -->
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.08] tracking-tight mb-5" style="text-wrap: balance;">
              <BlurText
                client:visible
                text="Ship Your AI Agent"
                delay={150}
                animateBy="words"
                direction="top"
                className="text-white"
              />
            </h1>

            <p class="text-base sm:text-lg text-silver/60 max-w-xl mb-8 leading-relaxed animate-fade-in-up animation-delay-100" style="text-wrap: balance;">
              The production playbook for indie hackers. 10 chapters covering architecture, memory, tools, multi-agent systems &mdash; plus 5 agents you can build this weekend.
            </p>

            <!-- Highlights list -->
            <ul class="space-y-2.5 mb-8 animate-fade-in-up animation-delay-150" role="list">
              {highlights.slice(0, 4).map((h) => (
                <li class="flex items-center gap-2.5 text-sm text-silver/70 lg:justify-start justify-center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F2E9E4" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  {h}
                </li>
              ))}
            </ul>

            <!-- Mobile stats strip (small screens only) -->
            <div class="flex md:hidden items-center justify-center gap-6 mb-8 animate-fade-in-up animation-delay-150">
              <div class="text-center">
                <div class="text-2xl font-extrabold text-cream">31K+</div>
                <div class="text-[10px] text-silver/40 uppercase tracking-wide">Words</div>
              </div>
              <div class="w-px h-8 bg-cream/10"></div>
              <div class="text-center">
                <div class="text-2xl font-extrabold text-cream">85+</div>
                <div class="text-[10px] text-silver/40 uppercase tracking-wide">Pages</div>
              </div>
              <div class="w-px h-8 bg-cream/10"></div>
              <div class="text-center">
                <div class="text-2xl font-extrabold text-cream">10</div>
                <div class="text-[10px] text-silver/40 uppercase tracking-wide">Chapters</div>
              </div>
            </div>

            <!-- Price + CTA -->
            <div class="animate-fade-in-up animation-delay-200">
              <div class="flex items-baseline gap-3 mb-5 lg:justify-start justify-center">
                <span class="text-5xl font-extrabold text-cream tabular-nums">$29</span>
                <span class="text-silver/40 text-sm">one-time &middot; instant download</span>
              </div>

              <div class="flex flex-col sm:flex-row items-center gap-4 lg:justify-start justify-center">
                <Magnet client:visible padding={60} magnetStrength={3}>
                  <AnimatedButton
                    client:visible
                    href={CHECKOUT_URL}
                    glow={true}
                    shimmerColor="#F2E9E4"
                    shimmerDuration="3s"
                    background="linear-gradient(135deg, #F2E9E4, #BFBCBA)"
                    className="!text-[#0D0D0D]"
                  >
                    Get the Playbook
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </AnimatedButton>
                </Magnet>
                <span class="text-xs text-silver/35">PDF &middot; Read anywhere &middot; Keep forever</span>
              </div>
            </div>
          </div>

          <!-- Right: Book mockup / Preview -->
          <div class="relative animate-fade-in-up animation-delay-300 hidden md:block">
            <div class="relative">
              <!-- Book shadow -->
              <div class="absolute inset-4 bg-cream/5 rounded-2xl blur-[40px]"></div>

              <!-- Book visual -->
              <div class="relative bg-[#0f172a] rounded-2xl border border-cream/10 overflow-hidden shadow-2xl shadow-cream/5">
                <!-- Title bar -->
                <div class="px-6 py-4 border-b border-cream/8 flex items-center gap-3">
                  <div class="flex gap-1.5">
                    <div class="w-2.5 h-2.5 rounded-full bg-cream/20"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-cream/15"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-cream/10"></div>
                  </div>
                  <span class="text-xs text-cream/30 font-mono">ship-your-ai-agent.pdf</span>
                </div>

                <!-- Content preview -->
                <div class="p-6 space-y-4">
                  <div class="text-center pb-4 border-b border-cream/8">
                    <p class="text-[10px] uppercase tracking-[0.2em] text-cream/30 mb-2">A SyncLabs Production Playbook</p>
                    <h3 class="text-2xl font-extrabold text-cream mb-1">Ship Your AI Agent</h3>
                    <p class="text-xs text-cream/40">The complete guide to building, deploying &amp; monetizing</p>
                  </div>

                  <!-- Table of contents preview -->
                  <div class="space-y-2.5">
                    <p class="text-[10px] uppercase tracking-[0.15em] text-cream/25 font-semibold">Table of Contents</p>
                    {chapters.slice(0, 6).map((ch) => (
                      <div class="flex items-center gap-3 group">
                        <span class="text-[10px] font-mono text-cream/20 w-4 tabular-nums">{ch.num}</span>
                        <span class="text-xs text-cream/50 group-hover:text-cream/70 transition-colors">{ch.title}</span>
                      </div>
                    ))}
                    <div class="flex items-center gap-3">
                      <span class="text-[10px] font-mono text-cream/20 w-4"></span>
                      <span class="text-xs text-cream/25 italic">+ 4 more chapters&hellip;</span>
                    </div>
                  </div>
                </div>

                <!-- Fade overlay -->
                <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-[#0f172a] to-transparent"></div>
              </div>

              <!-- Floating badges -->
              <div class="absolute -right-4 top-12 bg-surface border border-cream/15 rounded-lg px-3 py-2 shadow-xl">
                <div class="flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F2E9E4" stroke-width="2" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                  <span class="text-xs text-cream/70 font-medium">Code included</span>
                </div>
              </div>
              <div class="absolute -left-4 bottom-20 bg-surface border border-cream/15 rounded-lg px-3 py-2 shadow-xl">
                <div class="flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F2E9E4" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  <span class="text-xs text-cream/70 font-medium">85+ pages</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== SOCIAL PROOF BAR ===== -->
    <section class="relative py-10 border-t border-b border-cream/8 bg-cream/[0.02]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <StatsCount
          client:visible
          stats={stats}
          showDividers={true}
        />
      </div>
    </section>

    <!-- ===== WHAT'S INSIDE ===== -->
    <section class="relative py-24 lg:py-32">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section header -->
        <div class="text-center mb-16 max-w-2xl mx-auto">
          <span class="inline-block text-[11px] font-semibold tracking-[0.2em] uppercase text-cream/50 mb-4">What&rsquo;s Inside</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-cream leading-tight mb-4" style="text-wrap: balance;">
            10 chapters. Zero fluff. All production-ready.
          </h2>
          <p class="text-silver/45 text-base leading-relaxed">
            Every chapter includes working code, architecture diagrams, and patterns you can ship today.
          </p>
        </div>

        <!-- Chapter grid -->
        <div class="grid md:grid-cols-2 gap-4">
          {chapters.map((ch, i) => (
            <SpotlightCard
              client:visible
              className="rounded-xl border border-cream/8 bg-cream/[0.02] p-5 hover:border-cream/20 transition-all duration-300 group"
              spotlightColor="rgba(242, 233, 228, 0.06)"
            >
              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-lg bg-cream/8 text-cream/70 text-xs font-bold font-mono tabular-nums group-hover:bg-cream/12 transition-colors">
                  {ch.num}
                </span>
                <div class="min-w-0">
                  <h3 class="text-sm font-semibold text-cream mb-0.5 leading-snug">{ch.title}</h3>
                  <p class="text-xs text-silver/40 leading-relaxed">{ch.desc}</p>
                </div>
              </div>
            </SpotlightCard>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== WHAT YOU'LL GET ===== -->
    <section class="relative py-20 lg:py-28 border-t border-cream/8">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="inline-block text-[11px] font-semibold tracking-[0.2em] uppercase text-cream/50 mb-4">What You Get</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-cream leading-tight" style="text-wrap: balance;">
            Everything to go from idea to revenue
          </h2>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          {highlights.map((h) => (
            <div class="flex items-start gap-3 p-4 rounded-xl border border-cream/6 bg-cream/[0.02] hover:border-cream/15 transition-colors">
              <div class="flex-shrink-0 w-7 h-7 rounded-md bg-cream/10 flex items-center justify-center mt-0.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F2E9E4" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span class="text-sm text-cream/70 leading-relaxed">{h}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== WHO IT'S FOR ===== -->
    <section class="relative py-20 lg:py-28 border-t border-cream/8">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <span class="inline-block text-[11px] font-semibold tracking-[0.2em] uppercase text-cream/50 mb-4">Who It&rsquo;s For</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-cream leading-tight" style="text-wrap: balance;">
            Built for builders who ship
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-5">
          {audiences.map((a) => (
            <div class="rounded-xl border border-cream/8 bg-cream/[0.02] p-6 hover:border-cream/20 transition-all duration-300 group">
              <div class="w-11 h-11 rounded-xl bg-cream/8 flex items-center justify-center text-cream/60 mb-5 group-hover:bg-cream/12 transition-colors">
                <Fragment set:html={a.icon} />
              </div>
              <h3 class="text-base font-semibold text-cream mb-2">{a.title}</h3>
              <p class="text-sm text-silver/40 leading-relaxed">{a.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== GUARANTEE ===== -->
    <section class="relative py-16 border-t border-cream/8">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="w-14 h-14 mx-auto rounded-2xl bg-cream/8 flex items-center justify-center mb-5">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F2E9E4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-label="Guarantee shield">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <polyline points="9 12 11 14 15 10" stroke-width="2"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-cream mb-2">No-questions-asked refund</h3>
        <p class="text-sm text-silver/40 leading-relaxed max-w-md mx-auto">
          If the playbook doesn&rsquo;t help you build and ship an AI agent, email us within 30 days for a full refund. No hoops, no forms.
        </p>
      </div>
    </section>

    <!-- ===== FINAL CTA ===== -->
    <section class="relative py-16 lg:py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <ClickSpark client:visible sparkColor="#F2E9E4" sparkCount={12} sparkRadius={25} duration={500}>
          <div class="relative rounded-2xl overflow-hidden">
            <!-- Background -->
            <div class="absolute inset-0 bg-gradient-to-br from-[#1a1918] via-[#252320] to-[#1a1918]"></div>
            <div class="absolute top-0 right-0 w-80 h-80 bg-cream/8 rounded-full blur-[120px]"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 bg-cream/6 rounded-full blur-[100px]"></div>

            <div class="relative z-10 py-16 lg:py-20 px-6 lg:px-12 text-center">
              <h2 class="text-3xl sm:text-4xl font-extrabold text-cream leading-tight max-w-2xl mx-auto mb-4" style="text-wrap: balance;">
                <RevealText client:visible mode="auto" stagger={0.1} className="inline">
                  Stop prototyping. Start shipping.
                </RevealText>
              </h2>

              <p class="text-base text-cream/50 max-w-lg mx-auto mb-8">
                Everything you need to build, deploy, and monetize AI agents &mdash; in one guide.
              </p>

              <div class="flex items-baseline justify-center gap-3 mb-6">
                <span class="text-4xl font-extrabold text-white tabular-nums">$29</span>
                <span class="text-cream/40 text-sm">one-time</span>
              </div>

              <div class="flex flex-col items-center justify-center gap-4">
                <Magnet client:visible padding={60} magnetStrength={3}>
                  <AnimatedButton
                    client:visible
                    href={CHECKOUT_URL}
                    glow={true}
                    shimmerColor="#ffffff"
                    shimmerDuration="2.5s"
                    background="rgba(255,255,255,1)"
                    className="!text-[#0D1E30]"
                  >
                    <span style="color: #0D1E30">Get the Playbook</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0D1E30" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </AnimatedButton>
                </Magnet>
                <div class="flex items-center gap-4 text-xs text-cream/30">
                  <span class="flex items-center gap-1.5">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    30-day refund
                  </span>
                  <span class="flex items-center gap-1.5">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Instant download
                  </span>
                  <span class="flex items-center gap-1.5">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    PDF format
                  </span>
                </div>
              </div>
            </div>
          </div>
        </ClickSpark>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
