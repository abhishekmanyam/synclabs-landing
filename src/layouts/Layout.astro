---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sync Labs - AI Lip Sync Video Generator | Free Trial",
  description = "Create hyper-realistic lip-synced videos in minutes with AI. Upload video and audio, get perfect lip sync. 3 free videos. No credit card required."
} = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="AI lip sync, video dubbing, lip sync generator, talking head video, video localization, MuseTalk, AI video, lip sync AI, video AI" />
    <meta name="author" content="Sync Labs" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://synclabs.ai" />
    <meta property="og:image" content="https://synclabs.ai/images/hero.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Sync Labs" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://synclabs.ai/images/hero.png" />

    <!-- Additional SEO -->
    <link rel="canonical" href="https://synclabs.ai" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#2bf8d4" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/png" href="/synclabs.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen text-light-text antialiased" style="background-color: #0a1c30;">
    <slot />
  </body>
</html>
