---

const steps = [
  {

    title: "Upload Your Video",
    description: "Start by uploading any video file with a visible face. Our platform supports multiple formats including MP4, MOV, AVI, and more. The video can be a selfie, professional recording, or any existing footage.",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>`,
  },
  {

    title: "Add Your Audio",
    description: "Upload the audio you want to sync with your video. This can be in any language - our AI automatically detects the language and analyzes the speech patterns, timing, and phonetics to ensure perfect synchronization.",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
  },
  {

    title: "Get Your Synced Video",
    description: "Our AI processes your video and creates perfectly synchronized lip movements that match your audio. In just 2-3 minutes, you'll have a professional-quality video ready to download and share across any platform.",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`,
  },
];


---

<section id="how-it-works" class="relative pt-4 pb-12 lg:pt-6 lg:pb-16">
  <!-- Background orb -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-cream/5 rounded-full blur-[200px]"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-20">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-cream leading-tight">
        How It Works
      </h2>
    </div>

    <!-- Steps -->
    <div class="grid lg:grid-cols-3 gap-8 lg:gap-12 mb-10">
      {steps.map((step, i) => (
        <div class="group relative">
          <div class="relative h-full p-8 rounded-2xl bg-surface border border-border hover:border-border-light transition-all duration-300">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-cream to-silver flex items-center justify-center text-black">
                <Fragment set:html={step.icon} />
              </div>
            </div>
            <h3 class="text-xl font-bold text-cream mb-3">{step.title}</h3>
            <p class="text-silver/70 leading-relaxed">{step.description}</p>
            <!-- Hover glow effect -->
            <div
              class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
              style="background: radial-gradient(circle at 50% 0%, rgba(242, 233, 228, 0.12), transparent 70%);"
            ></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Avatar Showcase Section -->
    <div class="mb-24">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h3 class="text-3xl sm:text-4xl font-extrabold text-cream leading-tight mb-6">
          Meet our V1 Avatars
        </h3>
        <p class="text-lg text-silver/70">
          Watch how our AI transforms input videos with perfect lip synchronization.
        </p>
      </div>

      <!-- Avatar Pills Grid -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 max-w-4xl mx-auto">
        <!-- Avatar 1 - Jessica -->
        <div class="avatar-pill group relative overflow-hidden rounded-[2.5rem] bg-surface border border-border hover:border-border-light transition-all duration-300 cursor-pointer hover:scale-[1.02] w-full sm:w-72">
          <div class="relative bg-charcoal overflow-hidden" style="aspect-ratio: 9/16;">
            <video
              class="avatar-video w-full h-full object-cover"
              muted
              loop
              playsinline
              preload="metadata"
            >
              <source src="/images/input-video-1.mp4" type="video/mp4" />
            </video>
            <!-- Play icon overlay -->
            <div class="avatar-play-overlay absolute inset-0 flex items-center justify-center bg-black/30 transition-opacity duration-300">
              <div class="w-16 h-16 rounded-full bg-cream/20 backdrop-blur-sm flex items-center justify-center border border-cream/30">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-cream ml-1">
                  <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
              </div>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/70 to-transparent">
            <p class="text-cream font-semibold text-lg">Jessica</p>
          </div>
        </div>

        <!-- Avatar 2 - Jack -->
        <div class="avatar-pill group relative overflow-hidden rounded-[2.5rem] bg-surface border border-border hover:border-border-light transition-all duration-300 cursor-pointer hover:scale-[1.02] w-full sm:w-72">
          <div class="relative bg-charcoal overflow-hidden" style="aspect-ratio: 9/16;">
            <video
              class="avatar-video w-full h-full object-cover"
              muted
              loop
              playsinline
              preload="metadata"
            >
              <source src="/images/input-video-2.mp4" type="video/mp4" />
            </video>
            <!-- Play icon overlay -->
            <div class="avatar-play-overlay absolute inset-0 flex items-center justify-center bg-black/30 transition-opacity duration-300">
              <div class="w-16 h-16 rounded-full bg-cream/20 backdrop-blur-sm flex items-center justify-center border border-cream/30">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-cream ml-1">
                  <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
              </div>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/70 to-transparent">
            <p class="text-cream font-semibold text-lg">Jack</p>
          </div>
        </div>

        <!-- Avatar 3 - Sarah -->
        <div class="avatar-pill group relative overflow-hidden rounded-[2.5rem] bg-surface border border-border hover:border-border-light transition-all duration-300 cursor-pointer hover:scale-[1.02] w-full sm:w-72">
          <div class="relative bg-charcoal overflow-hidden" style="aspect-ratio: 9/16;">
            <video
              class="avatar-video w-full h-full object-cover"
              muted
              loop
              playsinline
              preload="metadata"
            >
              <source src="/images/input-video-3.mp4" type="video/mp4" />
            </video>
            <!-- Play icon overlay -->
            <div class="avatar-play-overlay absolute inset-0 flex items-center justify-center bg-black/30 transition-opacity duration-300">
              <div class="w-16 h-16 rounded-full bg-cream/20 backdrop-blur-sm flex items-center justify-center border border-cream/30">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-cream ml-1">
                  <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
              </div>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/70 to-transparent">
            <p class="text-cream font-semibold text-lg">Sarah</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('.avatar-pill').forEach((pill) => {
    const video = pill.querySelector('.avatar-video') as HTMLVideoElement;
    const overlay = pill.querySelector('.avatar-play-overlay') as HTMLElement;

    if (!video || !overlay) return;

    pill.addEventListener('mouseenter', () => {
      video.play();
      overlay.style.opacity = '0';
    });

    pill.addEventListener('mouseleave', () => {
      video.pause();
      video.currentTime = 0;
      overlay.style.opacity = '1';
    });
  });
</script>
