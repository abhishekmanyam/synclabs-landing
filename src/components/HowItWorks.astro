---
import RevealText from './ui/RevealText';

const steps = [
  {
    number: "01",
    title: "Upload Your Video",
    description: "Start by uploading any video file with a visible face. Our platform supports multiple formats including MP4, MOV, AVI, and more. The video can be a selfie, professional recording, or any existing footage.",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>`,
  },
  {
    number: "02",
    title: "Add Your Audio",
    description: "Upload the audio you want to sync with your video. This can be in any language - our AI automatically detects the language and analyzes the speech patterns, timing, and phonetics to ensure perfect synchronization.",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
  },
  {
    number: "03",
    title: "Get Your Synced Video",
    description: "Our AI processes your video and creates perfectly synchronized lip movements that match your audio. In just 2-3 minutes, you'll have a professional-quality video ready to download and share across any platform.",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`,
  },
];

const technicalSteps = [
  {
    title: "Face Detection & Analysis",
    description: "Our AI identifies and tracks facial landmarks with sub-pixel precision, mapping key points around the mouth, jaw, and surrounding facial features to understand the natural structure and movement patterns.",
    color: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)"
  },
  {
    title: "Audio Processing & Phoneme Extraction",
    description: "The audio is analyzed to extract phonemes (individual speech sounds), timing information, and prosodic features like pitch and rhythm. This creates a detailed map of what mouth shapes should appear at each moment.",
    color: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)"
  },
  {
    title: "Motion Synthesis",
    description: "Advanced neural networks generate natural lip and jaw movements that correspond to each phoneme. The AI considers co-articulation (how sounds blend together) and maintains the person's unique speaking style and facial expressions.",
    color: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)"
  },
  {
    title: "Temporal Alignment",
    description: "The generated mouth movements are precisely synchronized with the audio timeline, ensuring perfect frame-by-frame alignment. The system accounts for natural delays and transitions between different mouth positions.",
    color: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)"
  },
  {
    title: "Visual Blending & Refinement",
    description: "The synthesized lip movements are seamlessly blended into the original video, preserving lighting, skin texture, and facial expressions. Advanced techniques ensure smooth transitions and natural-looking results without visible artifacts.",
    color: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)"
  },
  {
    title: "Quality Enhancement",
    description: "Final post-processing optimizes the video quality, removes any temporal inconsistencies, and ensures smooth playback. The output maintains the original video resolution and quality while delivering perfectly synced lip movements.",
    color: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)"
  }
];

---

<section id="how-it-works" class="relative py-12 lg:py-16">
  <!-- Background orb -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-cream/5 rounded-full blur-[200px]"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header with RevealText -->
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-20">
      <span class="inline-block text-sm font-semibold text-silver uppercase tracking-widest mb-4">How It Works</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-cream leading-tight">
        <RevealText client:visible mode="auto" stagger={0.12} className="inline">
          Three Simple Steps
        </RevealText>
      </h2>
      <p class="mt-6 text-lg text-silver/70 max-w-2xl mx-auto">
        No video editing skills required. Our AI handles everything — you just upload your content and let us do the rest.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid lg:grid-cols-3 gap-8 lg:gap-12 mb-24">
      {steps.map((step, i) => (
        <div class="group relative">
          <div class="relative h-full p-8 rounded-2xl bg-surface border border-border hover:border-border-light transition-all duration-300">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-cream to-silver flex items-center justify-center text-black">
                <Fragment set:html={step.icon} />
              </div>
              <span class="text-6xl font-black text-border">{step.number}</span>
            </div>
            <h3 class="text-xl font-bold text-cream mb-3">{step.title}</h3>
            <p class="text-silver/70 leading-relaxed">{step.description}</p>
            <!-- Hover glow effect -->
            <div
              class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
              style="background: radial-gradient(circle at 50% 0%, rgba(242, 233, 228, 0.12), transparent 70%);"
            ></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Video Demonstration Section -->
    <div class="mb-24">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="inline-block text-sm font-semibold text-silver uppercase tracking-widest mb-4">See It In Action</span>
        <h3 class="text-3xl sm:text-4xl font-extrabold text-cream leading-tight mb-6">
          Real Examples
        </h3>
        <p class="text-lg text-silver/70">
          Watch how our AI transforms input videos with perfect lip synchronization.
        </p>
      </div>

      <!-- Video Grid - Pill Style -->
      <div class="flex flex-col sm:flex-row gap-6 max-w-6xl mx-auto">
        <!-- Video 1 - Jessica -->
        <div class="flex-1 group relative overflow-hidden rounded-3xl bg-surface border border-border hover:border-border-light transition-all duration-300">
          <div class="p-4 text-center border-b border-border">
            <h4 class="text-base font-bold text-cream">Jessica</h4>
          </div>
          <div class="relative bg-charcoal overflow-hidden" style="aspect-ratio: 16/9;">
            <video 
              class="w-full h-full object-contain"
              controls
              preload="metadata"
              poster="/images/input-image-1.png"
            >
              <source src="/images/input-video-1.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>

        <!-- Video 2 - Michael -->
        <div class="flex-1 group relative overflow-hidden rounded-3xl bg-surface border border-border hover:border-border-light transition-all duration-300">
          <div class="p-4 text-center border-b border-border">
            <h4 class="text-base font-bold text-cream">Michael</h4>
          </div>
          <div class="relative bg-charcoal overflow-hidden" style="aspect-ratio: 16/9;">
            <video 
              class="w-full h-full object-contain"
              controls
              preload="metadata"
              poster="/images/input-image-2.png"
            >
              <source src="/images/input-video-2.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>
      </div>
    </div>

    <!-- Technical Deep Dive -->
    <div class="mt-32">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block text-sm font-semibold text-silver uppercase tracking-widest mb-4">The Technology</span>
        <h3 class="text-3xl sm:text-4xl font-extrabold text-cream leading-tight mb-6">
          AI Lip-Sync Pipeline
        </h3>
        <p class="text-lg text-silver/70">
          Behind the scenes, our advanced AI processes your video through multiple stages to deliver photorealistic lip synchronization.
        </p>
      </div>

      <!-- Technical Steps Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {technicalSteps.map((step, index) => (
          <div class="group relative">
            <div class="relative h-full p-8 rounded-2xl bg-surface border border-border hover:border-border-light transition-all duration-300">
              <!-- Icon -->
              <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${step.color} flex items-center justify-center text-black mb-6 font-bold text-lg`}>
                {index + 1}
              </div>

              <!-- Content -->
              <h3 class="text-xl font-bold text-cream mb-3">{step.title}</h3>
              <p class="text-silver/70 leading-relaxed">{step.description}</p>

              <!-- Hover glow effect -->
              <div 
                class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
                style={`background: radial-gradient(circle at 50% 0%, ${step.spotlightColor}, transparent 70%);`}
              ></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Technical Highlights -->
      <div class="mt-16 grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="text-4xl font-black text-cream mb-2">30+ FPS</div>
          <p class="text-silver/60 text-sm">Real-time processing speed for smooth, natural motion</p>
        </div>
        <div class="text-center">
          <div class="text-4xl font-black text-silver mb-2">Sub-Frame</div>
          <p class="text-silver/60 text-sm">Precision timing for perfect audio-visual alignment</p>
        </div>
        <div class="text-center">
          <div class="text-4xl font-black text-cream mb-2">Multi-Language</div>
          <p class="text-silver/60 text-sm">Automatic language detection and phoneme mapping</p>
        </div>
      </div>
    </div>

  </div>
</section>
