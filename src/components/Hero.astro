---
import BlurText from './ui/BlurText';
import GradientText from './ui/GradientText';
import AnimatedButton from './ui/AnimatedButton';
import Magnet from './ui/Magnet';
---

<section class="relative min-h-screen flex flex-col justify-center pt-24 pb-12 noise-overlay">
  <!-- Subtle background glow -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-cream/5 rounded-full blur-[180px]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Centered hero copy -->
    <div class="text-center max-w-4xl mx-auto mb-12 lg:mb-16">
      <!-- Badge -->
    <div class="animate-fade-in-up mb-8">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-overlay-medium border border-border-light text-sm font-medium text-silver">
        <span class="w-2 h-2 rounded-full bg-cream animate-pulse"></span>
        Now in Early Access — 3 Free Videos
      </span>
    </div>

      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-light leading-[1.05] tracking-tight mb-6">
        <BlurText
          client:visible
          text="Create Hyper-Realistic"
          delay={150}
          animateBy="words"
          direction="top"
          className="text-white"
        />
        <br class="hidden sm:block" />
        <GradientText
          client:visible
          colors={["#F2E9E4", "#BFBCBA", "#F2E9E4", "#BFBCBA", "#F2E9E4"]}
          animationSpeed={4}
        >
          Lip-Synced Videos
        </GradientText>
        <BlurText
          client:visible
          text=" in Minutes"
          delay={150}
          animateBy="words"
          direction="top"
          className="text-white"
        />
      </h1>

      <!-- Key Benefits -->
    <div class="flex flex-wrap items-center justify-center gap-6 mb-12 text-sm text-silver/70 animate-fade-in-up animation-delay-200">
      <div class="flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span>Results in 2–3 minutes</span>
      </div>
      <div class="flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span>Powered by MuseTalk + Whisper</span>
      </div>
      <div class="flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span>3 free videos, no card needed</span>
      </div>
    </div>

      <!-- CTAs -->
      <div class="flex flex-col items-center gap-4 mt-10 animate-fade-in-up animation-delay-300">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Magnet client:visible padding={60} magnetStrength={3}>
            <AnimatedButton
              client:visible
              href="#pricing"
              glow={true}
              shimmerColor="#F2E9E4"
              shimmerDuration="3s"
              background="linear-gradient(135deg, #F2E9E4, #BFBCBA)"
              className="!text-[#0D0D0D]"
            >
              Create Your First Video Free
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </AnimatedButton>
          </Magnet>
          <a href="#how-it-works" class="btn-secondary text-base">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polygon points="10 8 16 12 10 16 10 8"></polygon>
            </svg>
            Watch Demo
          </a>
        </div>
        <span class="text-xs text-silver/40">No credit card required • 3 free videos</span>
      </div>
    </div>

    <!-- Product showcase: bento-style grid -->
    <div class="animate-fade-in-up animation-delay-400">
      <div class="relative max-w-5xl mx-auto">
        <!-- Main product screenshot -->
        <div class="relative rounded-2xl overflow-hidden border border-border shadow-2xl shadow-cream/5">
          <img
            src="/images/hero-product.png"
            alt="Sync Labs lip-sync dashboard"
            class="w-full h-auto"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
        </div>

        <!-- Floating card: Input Image Example -->
        <div class="absolute -left-4 lg:-left-12 bottom-2 lg:bottom-4 w-48 sm:w-56 lg:w-72 rounded-xl overflow-hidden border border-border shadow-xl shadow-black/60 hero-card-left">
          <img
            src="/images/input-image-1.png"
            alt="Input image example for lip sync"
            class="w-full h-auto"
            loading="eager"
          />
        </div>

        <!-- Floating card: Input Image 2 -->
        <div class="absolute -right-4 lg:-right-12 top-8 lg:top-16 w-40 sm:w-48 lg:w-60 rounded-xl overflow-hidden border border-border shadow-xl shadow-black/60 hero-card-right">
          <img
            src="/images/input-image-2.png"
            alt="Second input image example"
            class="w-full h-auto"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-card-left {
    backdrop-filter: blur(2px);
  }
  .hero-card-right {
    backdrop-filter: blur(2px);
  }

  @media (max-width: 640px) {
    .hero-card-left {
      left: 0 !important;
      bottom: -1rem !important;
    }
    .hero-card-right {
      right: 0 !important;
      top: -1rem !important;
    }
  }
</style>
