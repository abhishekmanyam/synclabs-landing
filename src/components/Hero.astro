---
import BlurText from './ui/BlurText';
import GradientText from './ui/GradientText';
import AnimatedButton from './ui/AnimatedButton';
import Magnet from './ui/Magnet';
---

<section class="relative min-h-screen flex flex-col justify-center pt-24 pb-12 noise-overlay">
  <!-- Subtle background glow -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-primary/8 rounded-full blur-[180px]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Centered hero copy -->
    <div class="text-center max-w-4xl mx-auto mb-12 lg:mb-16">
      <!-- Badge -->
      <div class="animate-fade-in-up mb-8">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-sm font-medium text-primary-light">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          Now with Nano Banana AI Image Generation
        </span>
      </div>

      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-extrabold leading-[1.05] tracking-tight mb-6">
        <BlurText
          client:visible
          text="Make Any Face"
          delay={150}
          animateBy="words"
          direction="top"
          className="text-white"
        />
        <br class="hidden sm:block" />
        <GradientText
          client:visible
          colors={["#2bf8d4", "#ffffff", "#2bf8d4", "#ffffff", "#2bf8d4"]}
          animationSpeed={4}
        >
          Speak
        </GradientText>
        <BlurText
          client:visible
          text=" with AI"
          delay={150}
          animateBy="words"
          direction="top"
          className="text-white"
        />
      </h1>

      <!-- Subheadline -->
      <p class="text-lg sm:text-xl text-light-text/50 max-w-2xl mx-auto leading-relaxed animate-fade-in-up animation-delay-200">
        Upload a photo, add audio, and get hyper-realistic lip-synced video in minutes. No editing skills needed.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-10 animate-fade-in-up animation-delay-400">
        <Magnet client:visible padding={60} magnetStrength={3}>
          <AnimatedButton
            client:visible
            href="#pricing"
            glow={true}
            shimmerColor="#2bf8d4"
            shimmerDuration="3s"
            background="linear-gradient(135deg, #2bf8d4, #1cc4a8)"
            className="!text-[#0D1E30]"
          >
            Start Creating Free
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </AnimatedButton>
        </Magnet>
        <a href="#how-it-works" class="btn-secondary text-base">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polygon points="10 8 16 12 10 16 10 8"></polygon>
          </svg>
          See How It Works
        </a>
      </div>
    </div>

    <!-- Product showcase: bento-style grid -->
    <div class="animate-fade-in-up animation-delay-600">
      <div class="relative max-w-5xl mx-auto">
        <!-- Main product screenshot -->
        <div class="relative rounded-2xl overflow-hidden border border-dark-border/60 shadow-2xl shadow-primary/5">
          <img
            src="/images/hero-product.png"
            alt="Sync Labs lip-sync dashboard"
            class="w-full h-auto"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/30 via-transparent to-transparent"></div>
        </div>

        <!-- Floating card: before/after -->
        <div class="absolute -left-4 lg:-left-12 bottom-8 lg:bottom-16 w-48 sm:w-56 lg:w-72 rounded-xl overflow-hidden border border-dark-border/60 shadow-xl shadow-dark/60 hero-card-left">
          <img
            src="/images/hero-before-after.png"
            alt="Before and after lip sync comparison"
            class="w-full h-auto"
            loading="eager"
          />
          <div class="absolute bottom-0 left-0 right-0 px-3 py-2 bg-gradient-to-t from-dark/90 to-transparent">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
              <span class="text-[10px] sm:text-xs text-light-text/70 font-medium">Before → After</span>
            </div>
          </div>
        </div>

        <!-- Floating card: multi-language -->
        <div class="absolute -right-4 lg:-right-12 top-8 lg:top-16 w-40 sm:w-48 lg:w-60 rounded-xl overflow-hidden border border-dark-border/60 shadow-xl shadow-dark/60 hero-card-right">
          <img
            src="/images/hero-languages.png"
            alt="Multi-language lip sync support"
            class="w-full h-auto"
            loading="eager"
          />
          <div class="absolute bottom-0 left-0 right-0 px-3 py-2 bg-gradient-to-t from-dark/90 to-transparent">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
              <span class="text-[10px] sm:text-xs text-light-text/70 font-medium">30+ Languages</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-card-left {
    backdrop-filter: blur(2px);
  }
  .hero-card-right {
    backdrop-filter: blur(2px);
  }

  @media (max-width: 640px) {
    .hero-card-left {
      left: 0 !important;
      bottom: -1rem !important;
    }
    .hero-card-right {
      right: 0 !important;
      top: -1rem !important;
    }
  }
</style>
