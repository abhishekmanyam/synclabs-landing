---
const useCases = [
  {
    title: "Video Ads",
    description: "Create spokesperson ads by swapping audio onto any face video. Update messaging instantly without a reshoot.",
  },
  {
    title: "Product Explainers",
    description: "Present your product with an AI avatar speaking your script. No camera, no studio, no talent fees.",
  },
  {
    title: "Social Media Content",
    description: "Turn voiceovers and podcast clips into talking-head videos for TikTok, Reels, and YouTube Shorts.",
  },
  {
    title: "How-To Videos",
    description: "Re-dub tutorials into any language automatically. Whisper detects the language — no manual transcription needed.",
  },
  {
    title: "Learning Courses",
    description: "Build training videos with AI presenters that speak your script. Produce course content at scale without on-camera talent.",
  },
  {
    title: "Video Localization",
    description: "Record once, dub into any language. Our AI re-syncs lip movements to the translated audio automatically.",
  },
];
---

<section id="use-cases" class="relative py-20 lg:py-28">
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-20">
      <span class="inline-block text-sm font-semibold text-silver uppercase tracking-widest mb-4">Use Cases</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-cream leading-tight" style="text-wrap: balance;">
        Built for Every
        <span class="gradient-text"> Creator & Business</span>
      </h2>
      <p class="mt-6 text-lg text-silver/70 max-w-2xl mx-auto">
        From solo creators to enterprise teams, Sync Labs powers lip-sync workflows across industries.
      </p>
    </div>

    <!-- Use cases grid -->
    <div class="grid md:grid-cols-2 gap-x-16 gap-y-10 max-w-4xl mx-auto">
      {useCases.map((useCase) => (
        <div class="group border-b border-border pb-8 hover:border-border-light transition-colors duration-200">
          <h3 class="text-xl font-bold text-cream mb-2 group-hover:text-silver transition-colors duration-200">{useCase.title}</h3>
          <p class="text-silver/60 text-sm leading-relaxed">{useCase.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
