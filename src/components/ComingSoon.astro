---
// Coming Soon section for planned features
---

<section id="coming-soon" class="relative py-12 lg:py-16 overflow-hidden">
  <div class="container-custom relative z-10">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-1.5 rounded-full bg-secondary/10 border border-secondary/20 text-sm font-medium text-silver mb-4">
        Coming Soon
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-cream mb-4">
        What's Next for Sync Labs
      </h2>
      <p class="text-lg text-silver/70 max-w-2xl mx-auto">
        We're constantly improving and adding new features. Here's what's in the pipeline.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <!-- Secure Cloud Storage -->
      <div class="gradient-border p-6 rounded-lg bg-dark-lighter/50 hover:bg-dark-lighter transition-colors">
        <div class="w-12 h-12 rounded-lg bg-cream/10 flex items-center justify-center mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-cream mb-2">Secure Cloud Storage</h3>
        <p class="text-silver/70 text-sm">
          Enterprise-grade secure storage for your videos with automatic retention management and privacy controls.
        </p>
      </div>

      <!-- Adjustable Parameters -->
      <div class="gradient-border p-6 rounded-lg bg-dark-lighter/50 hover:bg-dark-lighter transition-colors">
        <div class="w-12 h-12 rounded-lg bg-cream/10 flex items-center justify-center mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-cream mb-2">Advanced Parameters UI</h3>
        <p class="text-silver/70 text-sm">
          UI controls for bbox_shift, extra_margin, parsing mode (jaw/raw), and cheek width — for fine-tuned results on any face type.
        </p>
      </div>

      <!-- Model v1.5 -->
      <div class="gradient-border p-6 rounded-lg bg-dark-lighter/50 hover:bg-dark-lighter transition-colors">
        <div class="w-12 h-12 rounded-lg bg-cream/10 flex items-center justify-center mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-cream mb-2">MuseTalk v1.5 Model</h3>
        <p class="text-silver/70 text-sm">
          Upgraded model trained with GAN, perceptual, and sync losses for sharper results. Better identity preservation and more natural mouth motion.
        </p>
      </div>

      <!-- Text-to-Speech -->
      <div class="gradient-border p-6 rounded-lg bg-dark-lighter/50 hover:bg-dark-lighter transition-colors">
        <div class="w-12 h-12 rounded-lg bg-cream/10 flex items-center justify-center mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
            <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-cream mb-2">Text-to-Speech</h3>
        <p class="text-silver/70 text-sm">
          Type your script and let AI generate natural-sounding speech in multiple voices and languages.
        </p>
      </div>

      <!-- Developer API -->
      <div class="gradient-border p-6 rounded-lg bg-dark-lighter/50 hover:bg-dark-lighter transition-colors">
        <div class="w-12 h-12 rounded-lg bg-cream/10 flex items-center justify-center mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-cream mb-2">Developer API</h3>
        <p class="text-silver/70 text-sm">
          RESTful API with Python, Node.js SDKs. Webhooks, batch processing, and comprehensive documentation.
        </p>
      </div>

      <!-- Batch Processing -->
      <div class="gradient-border p-6 rounded-lg bg-dark-lighter/50 hover:bg-dark-lighter transition-colors">
        <div class="w-12 h-12 rounded-lg bg-cream/10 flex items-center justify-center mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
            <rect x="3" y="3" width="7" height="7"/>
            <rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-cream mb-2">Batch Processing</h3>
        <p class="text-silver/70 text-sm">
          Process multiple videos at once. Perfect for content creators with large video libraries.
        </p>
      </div>

      <!-- Advanced Analytics -->
      <div class="gradient-border p-6 rounded-lg bg-dark-lighter/50 hover:bg-dark-lighter transition-colors">
        <div class="w-12 h-12 rounded-lg bg-cream/10 flex items-center justify-center mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
            <line x1="18" y1="20" x2="18" y2="10"/>
            <line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="14"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-cream mb-2">Advanced Analytics</h3>
        <p class="text-silver/70 text-sm">
          Track usage, monitor processing times, and optimize your workflow with detailed insights.
        </p>
      </div>

      <!-- Extended Limits -->
      <div class="gradient-border p-6 rounded-lg bg-dark-lighter/50 hover:bg-dark-lighter transition-colors">
        <div class="w-12 h-12 rounded-lg bg-cream/10 flex items-center justify-center mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-cream mb-2">Extended Limits</h3>
        <p class="text-silver/70 text-sm">
          Longer videos, larger file sizes, and more monthly credits with Pro and Enterprise plans.
        </p>
      </div>

      <!-- Live Streaming -->
      <div class="gradient-border p-6 rounded-lg bg-dark-lighter/50 hover:bg-dark-lighter transition-colors">
        <div class="w-12 h-12 rounded-lg bg-cream/10 flex items-center justify-center mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
            <circle cx="12" cy="12" r="2"/>
            <path d="M16.72 7.28a6 6 0 0 1 0 9.44"/>
            <path d="M7.28 7.28a6 6 0 0 0 0 9.44"/>
            <path d="M20.66 3.34a12 12 0 0 1 0 17.32"/>
            <path d="M3.34 3.34a12 12 0 0 0 0 17.32"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-cream mb-2">Live Streaming</h3>
        <p class="text-silver/70 text-sm">
          Real-time lip sync for live streams and video calls. Broadcast with perfectly synced AI lip movements at ultra-low latency.
        </p>
      </div>

      <!-- Custom Avatars -->
      <div class="gradient-border p-6 rounded-lg bg-dark-lighter/50 hover:bg-dark-lighter transition-colors">
        <div class="w-12 h-12 rounded-lg bg-cream/10 flex items-center justify-center mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cream">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            <path d="M21 21v-2a4 4 0 0 0-3-3.87"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-cream mb-2">Custom Avatars</h3>
        <p class="text-silver/70 text-sm">
          Create and save your own AI avatars from photos or videos. Build a library of reusable digital personas for consistent branding.
        </p>
      </div>
    </div>

  </div>
</section>
