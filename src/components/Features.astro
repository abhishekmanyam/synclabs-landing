---
import RevealText from './ui/RevealText';
import TextHighlighter from './ui/TextHighlighter';
import FeatureCard from './ui/FeatureCard';

const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>`,
    title: "Hyper-Realistic Lip Sync",
    description: "Our proprietary AI model delivers industry-leading sync accuracy, producing natural mouth movements indistinguishable from real footage.",
    gradient: "from-primary to-primary-dark",
    spotlightColor: "rgba(43, 248, 212, 0.12)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
    title: "Nano Banana Image Gen",
    description: "No photo? No problem. Generate photorealistic AI faces directly in-platform with our Nano Banana integration. From text to talking head.",
    gradient: "from-amber-500 to-orange-600",
    spotlightColor: "rgba(245, 158, 11, 0.15)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: "30+ Language Support",
    description: "Dub content into 30+ languages with native-quality lip sync. Break language barriers and reach global audiences effortlessly.",
    gradient: "from-secondary to-cyan-600",
    spotlightColor: "rgba(6, 182, 212, 0.15)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: "Lightning Fast Rendering",
    description: "Get your lip-synced videos in under 2 minutes. Our GPU-accelerated pipeline processes videos 10x faster than alternatives.",
    gradient: "from-yellow-400 to-amber-500",
    spotlightColor: "rgba(250, 204, 21, 0.12)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="7.5 4.21 12 6.81 16.5 4.21"/><polyline points="7.5 19.79 7.5 14.6 3 12"/><polyline points="21 12 16.5 14.6 16.5 19.79"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
    title: "Powerful API",
    description: "Integrate lip sync into your workflow with our developer-friendly REST API. Process at scale with batch endpoints and webhooks.",
    gradient: "from-emerald-400 to-green-600",
    spotlightColor: "rgba(52, 211, 153, 0.12)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: "Enterprise Security",
    description: "SOC 2 compliant with end-to-end encryption. Your data is processed securely and never used for model training without consent.",
    gradient: "from-rose-400 to-red-600",
    spotlightColor: "rgba(244, 63, 94, 0.12)",
  },
];
---

<section id="features" class="relative py-24 lg:py-32">
  <!-- Background accent -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-primary/5 to-transparent"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header with RevealText -->
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-20">
      <span class="inline-block text-sm font-semibold text-secondary uppercase tracking-widest mb-4">Features</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
        <RevealText client:visible mode="auto" stagger={0.12} className="inline">
          Everything You Need to Create
        </RevealText>
        <TextHighlighter client:visible highlightColor="#2bf8d4" type="wavy" animationDuration={1.5} strokeWidth={3}>
          <span class="gradient-text"> Perfect Lip Sync</span>
        </TextHighlighter>
      </h2>
      <p class="mt-6 text-lg text-light-text/50 max-w-2xl mx-auto">
        From AI image generation to multi-language dubbing, Sync Labs gives you a complete toolkit for creating stunning lip-synced video content.
      </p>
    </div>

    <!-- Features grid with SpotlightCard -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {features.map((feature) => (
        <FeatureCard
          client:visible
          icon={feature.icon}
          title={feature.title}
          description={feature.description}
          gradient={feature.gradient}
          spotlightColor={feature.spotlightColor}
        />
      ))}
    </div>
  </div>
</section>
