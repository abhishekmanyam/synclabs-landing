---
import FeatureCard from './ui/FeatureCard.astro';

const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`,
    title: "AI Lip Sync",
    description: "Upload a video and audio track — our AI generates a perfectly lip-synced output with natural mouth movements. No editing skills required.",
    gradient: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: "Multi-Language Audio",
    description: "Powered by Whisper for automatic language detection. Sync any audio track — in any language — to your video without manual configuration.",
    gradient: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: "Fast Cloud Processing",
    description: "Jobs run on GPU-accelerated cloud infrastructure. Most videos under 30 seconds complete in 2–3 minutes. No local setup or hardware needed.",
    gradient: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>`,
    title: "Wide Format Support",
    description: "Upload MP4, MOV, AVI, FLV, or MKV video files up to 200 MB. Audio can be any FFmpeg-compatible format — MP3, WAV, M4A, AAC, and more.",
    gradient: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    title: "Private & Secure",
    description: "Input files are deleted immediately after processing. Output videos are retained for 7 days, then automatically removed. Your content stays yours.",
    gradient: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
    title: "Pre-Built Avatars",
    description: "Get started instantly with our library of AI avatars — including Sarah, Jack, and Jessica. No source video needed to create your first lip-synced clip.",
    gradient: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)",
  },
];
---

<section id="features" class="relative py-20 lg:py-28">
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-20">
      <span class="inline-block text-sm font-semibold text-silver uppercase tracking-widest mb-4">Features</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-cream leading-tight" style="text-wrap: balance;">
        Everything You Need for
        <span class="gradient-text"> Perfect Lip Sync</span>
      </h2>
      <p class="mt-6 text-lg text-silver/70 max-w-2xl mx-auto">
        Built on MuseTalk v1.5 with Whisper audio embeddings, VAE latent encoding, and BiSeNet face blending — running on GPU-accelerated cloud infrastructure.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <FeatureCard
          icon={feature.icon}
          title={feature.title}
          description={feature.description}
          gradient={feature.gradient}
          spotlightColor={feature.spotlightColor}
        />
      ))}
    </div>
  </div>
</section>
