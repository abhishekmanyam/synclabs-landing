---
import FeatureCard from './ui/FeatureCard.astro';

const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>`,
    title: "Real-Time Lip Sync",
    description: "Advanced AI model delivers natural mouth movements synchronized to any audio. Process videos in minutes with GPU-accelerated cloud infrastructure.",
    gradient: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: "Multi-Language Support",
    description: "Support for multiple languages with automatic language detection. Perfect for dubbing and localization of your content across global markets.",
    gradient: "from-cream to-silver",
    spotlightColor: "rgba(242, 233, 228, 0.12)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: "Lightning Fast Processing",
    description: "Real-time inference at 30fps+ on enterprise-grade GPUs. Most videos complete in 2-3 minutes. Cloud-based processing means no local setup required.",
    gradient: "from-silver to-cream",
    spotlightColor: "rgba(191, 187, 186, 0.12)",
  },
];
---

<section id="features" class="relative py-12 lg:py-16">
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-20">
      <span class="inline-block text-sm font-semibold text-silver uppercase tracking-widest mb-4">Features</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-cream leading-tight">
        Everything You Need for
        <span class="gradient-text"> Perfect Lip Sync</span>
      </h2>
      <p class="mt-6 text-lg text-silver/70 max-w-2xl mx-auto">
        Professional-grade AI technology that makes video lip-syncing accessible to everyone.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <FeatureCard
          icon={feature.icon}
          title={feature.title}
          description={feature.description}
          gradient={feature.gradient}
          spotlightColor={feature.spotlightColor}
        />
      ))}
    </div>
  </div>
</section>
