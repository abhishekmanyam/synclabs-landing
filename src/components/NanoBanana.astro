---
import RevealText from './ui/RevealText';
import AnimatedButton from './ui/AnimatedButton';
import Magnet from './ui/Magnet';
---

<section class="relative py-24 lg:py-32 grid-bg">
  <!-- Background accent -->
  <div class="absolute bottom-0 left-0 w-1/2 h-full bg-gradient-to-r from-amber-500/5 to-transparent"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Content -->
      <div class="space-y-8">
        <div>
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-sm font-medium text-amber-400 mb-6">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
            Powered by Nano Banana
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
            <RevealText client:visible mode="auto" stagger={0.12} className="inline">
              No Photo?
            </RevealText>
            <span class="bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent"> Generate One</span>
          </h2>
        </div>

        <p class="text-lg text-light-text/50 leading-relaxed max-w-xl">
          Don't have a headshot or face image? Use our integrated <strong class="text-amber-400">Nano Banana</strong> AI image generator to create photorealistic faces from a simple text description. Go from idea to lip-synced video — entirely with AI.
        </p>

        <!-- Feature list -->
        <ul class="space-y-4">
          {[
            "Generate photorealistic portraits from text prompts",
            "Create diverse AI characters for any campaign",
            "Seamlessly pipe generated images into lip sync",
            "Consistent character identity across multiple videos"
          ].map((item) => (
            <li class="flex items-start gap-3">
              <div class="mt-1 w-5 h-5 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center flex-shrink-0">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span class="text-light-text/70">{item}</span>
            </li>
          ))}
        </ul>

        <Magnet client:visible padding={60} magnetStrength={3}>
          <AnimatedButton
            client:visible
            href="#pricing"
            glow={true}
            shimmerColor="#f59e0b"
            shimmerDuration="3s"
            background="linear-gradient(135deg, #f59e0b, #ea580c)"
          >
            Try Nano Banana
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </AnimatedButton>
        </Magnet>
      </div>

      <!-- Image -->
      <div class="relative">
        <div class="rounded-2xl overflow-hidden" style="box-shadow: 0 0 40px rgba(245, 158, 11, 0.2), 0 0 80px rgba(245, 158, 11, 0.1);">
          <img
            src="/images/nano-banana.png"
            alt="Nano Banana AI image generation interface"
            class="w-full h-auto rounded-2xl"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/50 via-transparent to-transparent rounded-2xl"></div>
        </div>

        <!-- Prompt preview card -->
        <div class="absolute -bottom-6 left-4 right-4 gradient-border p-4">
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full bg-green-400 animate-pulse flex-shrink-0"></div>
            <p class="text-sm text-light-text/70 font-mono truncate">
              "Professional headshot, female, warm lighting, confident smile..."
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
