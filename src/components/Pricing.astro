---
const plans = [
  {
    name: "",
    price: "",
    period: "",
    description: "Perfect for trying out AI lip sync",
    features: [
      "1 free lip sync",
      "5 credits on new account creation",
      "GPU-accelerated processing",
      "7-day output retention",
      "No credit card required"
    ],
    cta: "Start Free",
    href: "https://app.synclabs.studio",
    highlighted: true,
    badge: "Available Now",
    comingSoon: false,
  },
  {
    name: "Pro",
    price: "$29.99",
    period: "/mo",
    description: "For creators scaling their content",
    features: [
      "Unlimited videos (up to 90 seconds each)",
      "200 MB max file size per upload",
      "Multiple video formats (MP4, AVI, MOV, FLV, MKV)",
      "Any audio format supported",
      "Multi-language support via Whisper",
      "Priority GPU processing",
      "API access with webhooks (coming soon)",
      "30-day output retention",
      "Email support",
    ],
    cta: "Get Pro",
    href: "https://app.synclabs.studio",
    highlighted: true,
    badge: "Available Now",
    comingSoon: false,
  },
  {
    name: "Enterprise",
    price: "Custom",
    period: "",
    description: "For teams with high-volume needs",
    features: [
      "Unlimited videos & duration",
      "Custom file size limits",
      "Dedicated GPU infrastructure",
      "Full API access + SDK",
      "Custom retention policies",
      "SSO & team management",
      "Premium support & SLA",
    ],
    cta: "Contact Us",
    href: "#",
    highlighted: false,
    badge: "Coming Soon",
    comingSoon: true,
  },
];
---

<section id="pricing" class="relative py-12 lg:py-16 overflow-hidden">
  <div class="container-custom relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-cream mb-4">
        Simple, Transparent Pricing
      </h2>
      <p class="text-lg text-silver/70 max-w-2xl mx-auto">
        Start for free. No credit card required. Paid plans with extended limits coming soon.
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {plans.map((plan) => (
        <div class="relative">
          <!-- Badge -->
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10">
            <span class={`px-4 py-1 rounded-full text-sm font-bold whitespace-nowrap ${plan.comingSoon ? 'bg-surface border border-border text-silver' : 'bg-cream text-black'}`}>
              {plan.badge}
            </span>
          </div>

          <div class={`relative h-full p-8 rounded-2xl border-2 ${plan.highlighted ? 'border-cream bg-surface' : 'border-border bg-surface/50'} ${plan.comingSoon ? 'opacity-70' : ''}`}>
            <div class="text-center mb-6">
              <h3 class="text-2xl font-bold text-cream mb-2">{plan.name}</h3>
              <div class="flex items-baseline justify-center gap-1 mb-2">
                {plan.price ? (
                  <>
                    <span class="text-5xl font-extrabold text-cream">{plan.price}</span>
                    <span class="text-silver/60">{plan.period}</span>
                  </>
                ) : (
                  <span class="text-3xl font-extrabold text-cream">{plan.cta}</span>
                )}
              </div>
              <p class="text-silver/70">{plan.description}</p>
            </div>

            <ul class="space-y-3 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-cream flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <polyline points="20 6 9 17 4 12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></polyline>
                  </svg>
                  <span class="text-silver/80">{feature}</span>
                </li>
              ))}
            </ul>

            {!plan.comingSoon && (
              <a
                href={plan.href}
                class="block w-full text-center py-3 px-6 rounded-lg font-semibold transition-all bg-cream text-black hover:bg-silver"
              >
                {plan.cta}
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Contact -->
    <div class="mt-12 text-center">
      <p class="text-silver/60">
        Have questions? Email us at <a href="mailto:info@synclabs.studio" class="text-cream hover:text-silver underline">info@synclabs.studio</a>
      </p>
    </div>
  </div>
</section>
