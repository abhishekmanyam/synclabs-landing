---
const trustBadges = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
    title: "Stripe-Secured",
    description: "Payments"
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    title: "256-bit",
    description: "Encryption"
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: "Files Auto-Deleted",
    description: "in 7 Days"
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
    title: "No Credit Card",
    description: "Required"
  },
];
---

<section class="relative py-16 border-y border-border/50 bg-surface/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-medium text-silver/40 uppercase tracking-widest mb-10">
      Trusted & Secure
    </p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 lg:gap-8">
      {trustBadges.map((badge) => (
        <div class="flex flex-col items-center text-center group">
          <div class="w-12 h-12 rounded-xl bg-cream/10 border border-cream/20 flex items-center justify-center text-cream mb-3 group-hover:bg-cream/20 transition-all">
            <Fragment set:html={badge.icon} />
          </div>
          <div class="text-sm font-semibold text-cream">{badge.title}</div>
          <div class="text-xs text-silver/50">{badge.description}</div>
        </div>
      ))}
    </div>
  </div>
</section>
