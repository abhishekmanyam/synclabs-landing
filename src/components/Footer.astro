---
const footerLinks = {
  Product: [
    { label: 'Features', href: '#features' },
    { label: 'How It Works', href: '#how-it-works' },
    { label: 'Pricing', href: '#pricing' },
  ],
  'Use Cases': [
    { label: 'AI Avatars', href: '#use-cases' },
    { label: 'Localization', href: '#use-cases' },
    { label: 'Marketing', href: '#use-cases' },
    { label: 'Training', href: '#use-cases' },
    { label: 'Social Media', href: '#use-cases' },
  ],
  Company: [
    { label: 'About', href: '#' },
    { label: 'Contact', href: 'mailto:info@synclabs.studio' },
  ],
  Legal: [
    { label: 'Privacy Policy', href: '#' },
    { label: 'Terms of Service', href: '#' },
  ],
};
---

<footer class="relative border-t border-dark-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid lg:grid-cols-6 gap-12 lg:gap-8">
      <!-- Brand column -->
      <div class="lg:col-span-2 space-y-6">
        <a href="/" class="flex items-center">
          <img src="/synclabs.png" alt="Sync Labs" class="h-16 sm:h-20 lg:h-24 w-auto" />
        </a>
        <p class="text-silver/40 text-sm leading-relaxed max-w-xs">
          AI-powered lip sync technology for creators, businesses, and developers. Make any face speak with perfect synchronization.
        </p>

      </div>

      <!-- Link columns -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h4 class="text-sm font-semibold text-cream mb-4">{category}</h4>
          <ul class="space-y-3">
            {links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-silver/40 hover:text-cream transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-dark-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-silver/30">
        &copy; {new Date().getFullYear()} Sync Labs. All rights reserved.
      </p>
    </div>
  </div>
</footer>
